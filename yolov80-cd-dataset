import argparse
import random
import shutil
from pathlib import Path

IMG_EXTS = {".png", ".jpg", ".jpeg", ".tif", ".tiff", ".bmp"}


def validate_label(txt: Path) -> bool:
    try:
        for line in txt.read_text().strip().splitlines():
            if not line.strip():
                continue
            parts = line.split()
            if len(parts) != 5:
                return False
            cls = int(parts[0])
            cx, cy, w, h = map(float, parts[1:])
            if cls != 0:
                return False
            if not all(0.0 <= v <= 1.0 for v in (cx, cy, w, h)):
                return False
    except (ValueError, OSError):
        return False
    return True


def main() -> None:
    ap = argparse.ArgumentParser()
    ap.add_argument("--images", required=True)
    ap.add_argument("--labels", required=True)
    ap.add_argument("--out", default="dataset")
    ap.add_argument("--val-frac", type=float, default=0.15)
    ap.add_argument("--seed", type=int, default=42)
    args = ap.parse_args()

    img_dir, lbl_dir, out = Path(args.images), Path(args.labels), Path(args.out)
    pairs = []
    skipped_no_label, skipped_bad_label = 0, 0

    for img in sorted(img_dir.iterdir()):
        if img.suffix.lower() not in IMG_EXTS:
            continue
        lbl = lbl_dir / (img.stem + ".txt")
        if not lbl.exists():
            skipped_no_label += 1
            continue
        if not validate_label(lbl):
            skipped_bad_label += 1
            continue
        pairs.append((img, lbl))

    if not pairs:
        raise SystemExit("No valid image/label pairs found — check paths and label format.")

    random.Random(args.seed).shuffle(pairs)
    n_val = max(1, int(len(pairs) * args.val_frac))
    splits = {"val": pairs[:n_val], "train": pairs[n_val:]}

    for split, items in splits.items():
        (out / "images" / split).mkdir(parents=True, exist_ok=True)
        (out / "labels" / split).mkdir(parents=True, exist_ok=True)
        for img, lbl in items:
            shutil.copy2(img, out / "images" / split / img.name)
            shutil.copy2(lbl, out / "labels" / split / lbl.name)

    print(f"train: {len(splits['train'])}  val: {len(splits['val'])}")
    print(f"skipped (no label): {skipped_no_label}  skipped (bad label): {skipped_bad_label}")
    print(f"Dataset written to {out.resolve()}")


if __name__ == "__main__":
    main()

